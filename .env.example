# ==== Core project ====
PROJECT_NAME=openclaw-starter
PROJECT_ROOT=.
LOG_LEVEL=INFO
ENVIRONMENT=dev

# ==== OpenClaw / model providers ====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ==== Docker infra ====
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379

# ==== Paths ====
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
MEMORY_DIR=./memory
LOGS_DIR=./logs
CONFIG_DIR=./config

# ==== Scraping defaults ====
HTTP_TIMEOUT_SECONDS=30
MAX_CONCURRENT_JOBS=4
USER_AGENT=Mozilla/5.0 (compatible; OpenClawStarter/1.0)
